# NikGapps configuration file
# Minimal GApps build for AxionOS Android 16
AndroidVersion=16
Version=38

LogDirectory=default
InstallPartition=default
Mode=install
WipeDalvikCache=1
WipeRuntimePermissions=1
ExecuteBackupRestore=1
UseZipConfig=0
OverwriteWithZipConfig=0
GmsOptimization=0
GenerateLogs=1

# ── CORE (mandatory) ──────────────────────────────────────────────────────────
Core=1
>>ExtraFiles=1
>>GooglePlayStore=1
>>GoogleServicesFramework=1
>>GoogleContactsSyncAdapter=1
>>GoogleCalendarSyncAdapter=1
>>GmsCore=1

# ── SETUP WIZARD ──────────────────────────────────────────────────────────────
SetupWizard=1
>>SetupWizard=1
>>GoogleRestore=1
>>GoogleOneTimeInitializer=1

# ── WANTED APPS ───────────────────────────────────────────────────────────────
GBoard=1
GooglePhotos=1
GoogleKeep=1
GoogleSearch=1
>>Velvet=1
>>Gemini=1

DigitalWellbeing=1
GoogleClock=1
GoogleCalculator=1
MarkupGoogle=1

# ── COMMUNICATION ─────────────────────────────────────────────────────────────
GoogleDialer=1
GoogleContacts=1
GoogleMessages=1
CarrierServices=1
GoogleCalendar=0

# ── FILES ─────────────────────────────────────────────────────────────────────
GoogleFiles=1
>>GoogleFiles=1
>>StorageManager=1
>>DocumentsUIGoogle=0

# ── CHROME — disabled, system WebView still needed ────────────────────────────
# TrichromeLibrary and WebViewGoogle are standalone packages in A16;
# set Chrome to 0 but keep WebView for system stability
GoogleChrome=0
>>GoogleChrome=0
>>WebViewGoogle=1
>>TrichromeLibrary=1

# ── PIXEL SPECIFICS — all disabled ───────────────────────────────────────────
PixelSpecifics=0
>>PixelLauncher=0
>>DevicePersonalizationServices=0
>>GoogleWallpaper=0
>>QuickAccessWallet=0
>>SettingsServices=0
>>PrivateComputeServices=0
>>PixelThemes=0
>>EmojiWallpaper=0
>>PixelWeather=0
>>AICore=0

# ── SKIPPED ───────────────────────────────────────────────────────────────────
DeviceHealthServices=0
PlayGames=0
GoogleRecorder=0
GoogleTTS=0
GoogleSounds=0
GoogleMaps=0
GoogleLocationHistory=0
Drive=0
Gmail=0
DeviceSetup=0
AndroidAuto=0
GoogleFeedback=0
GooglePartnerSetup=0
AndroidDevicePolicy=0

# ── GO APPS — not for AxionOS ────────────────────────────────────────────────
CoreGo=0
GoogleGo=0
AssistantGo=0
MapsGo=0
NavigationGo=0
GalleryGo=0
GmailGo=0

# ── ADDONS — all off ─────────────────────────────────────────────────────────
PixelSetupWizard=0
Meet=0
GoogleDocs=0
GoogleSheets=0
GoogleSlides=0
YouTube=0
YouTubeMusic=0
Books=0
GoogleTalkback=0
GooglePersonalSafety=0
