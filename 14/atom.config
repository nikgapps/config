# NikGapps configuration file

# If you are not sure about the config, just skip making changes to it or comment it by adding # before it
# visit https://nikgapps.com/misc/2022/02/22/NikGapps-Config.html to read everything about nikgapps

AndroidVersion=14

Version=37

LogDirectory=default
InstallPartition=default
Mode=install
WipeDalvikCache=1
WipeRuntimePermissions=0
ExecuteBackupRestore=1
UseZipConfig=0
OverwriteWithZipConfig=0
GmsOptimization=0
GenerateLogs=1

# ── CORE (required) ──────────────────────────
Core=1
>>ExtraFiles=1
>>GooglePlayStore=1
>>GoogleServicesFramework=1
>>GoogleContactsSyncAdapter=1
>>GoogleCalendarSyncAdapter=1
>>GmsCore=1

# ── BASIC ────────────────────────────────────
DigitalWellbeing=1
GoogleMessages=1
GoogleDialer=1
GoogleContacts=1
CarrierServices=1
GoogleClock=1

# ── SELECTED ADD-ONS ─────────────────────────
GoogleCalculator=1
GoogleMaps=1
GBoard=1
GoogleRecorder=1
AndroidAuto=1

# ── GOOGLE FILES ─────────────────────────────
GoogleFiles=1
>>GoogleFiles=1
>>StorageManager=1
>>DocumentsUIGoogle=1

# ── WEBVIEW (no Chrome) ──────────────────────
GoogleChrome=1
>>GoogleChrome=0
>>WebViewGoogle=1
>>TrichromeLibrary=1

# ── GALLERY GO ───────────────────────────────
GalleryGo=1

# ── EVERYTHING OFF ───────────────────────────
SetupWizard=0
>>SetupWizard=0
>>GoogleRestore=0
>>GoogleOneTimeInitializer=0
Drive=0
GoogleLocationHistory=0
GooglePhotos=0
DeviceHealthServices=0
GoogleCalendar=0
GoogleKeep=0
PixelSpecifics=0
>>PixelLauncher=0
>>DevicePersonalizationServices=0
>>GoogleWallpaper=0
>>QuickAccessWallet=0
>>SettingsServices=0
>>PrivateComputeServices=0
>>PixelThemes=0
>>EmojiWallpaper=0
>>PixelWeather=0
PlayGames=0
MarkupGoogle=0
GoogleTTS=0
GoogleSearch=0
>>Velvet=0
>>Assistant=0
GoogleSounds=0
Gmail=0
DeviceSetup=0
GoogleFeedback=0
GooglePartnerSetup=0
AndroidDevicePolicy=0
CoreGo=0
GoogleGo=0
AssistantGo=0
MapsGo=0
NavigationGo=0
GmailGo=0
PixelSetupWizard=0
Meet=0
GoogleDocs=0
GoogleSheets=0
GoogleSlides=0
YouTube=0
YouTubeMusic=0
Books=0
GoogleTalkback=0
