# NikGapps Configuration File for crDroid Android 15
# This config replaces AOSP apps with Google versions
# Value meanings:
#   0 = Exclude app
#   1 = Include app (keep AOSP version if exists)
#   2 = Include app AND remove AOSP version

# Core Google Services (Required - DO NOT CHANGE)
Core=1
>>ExtraFiles=1
>>GooglePlayStore=1
>>GoogleServicesFramework=1
>>GoogleContactsSyncAdapter=1
>>GoogleCalendarSyncAdapter=1
>>GmsCore=1
>>GmsCoreAutoSetup=1
>>Enrollment=1
>>GoogleRestore=1
>>GoogleExtShared=1
>>GoogleExtServices=1

# ===== AOSP REPLACEMENTS (Set to 2 to replace Lineage/AOSP apps) =====
# Phone, Contacts, Messages - Core replacements
Dialer=2                    # Replaces AOSP Dialer with Google Phone
Contacts=2                  # Replaces AOSP Contacts with Google Contacts  
Messaging=2                 # Replaces AOSP Messaging with Google Messages

# Additional AOSP replacements
Clock=2                     # Replaces AOSP Clock with Google Clock
Calculator=2                # Replaces AOSP Calculator with Google Calculator
Calendar=2                  # Replaces AOSP Calendar with Google Calendar
Keyboard=2                  # Replaces AOSP Keyboard with Gboard
Photos=2                    # Replaces AOSP Gallery with Google Photos

# ===== ADDITIONAL GOOGLE APPS (Set to 1 to include) =====
# Your requested apps
Maps=1                      # Google Maps
GoogleWallet=1              # Google Wallet
GoogleLens=1                # Google Lens
Meet=1                      # Google Meet

# Recommended additional apps for better experience
Chrome=1                    # Replaces AOSP Browser
Gmail=1
Drive=1
YouTube=1
Keep=1
GoogleFiles=1

# ===== OPTIONAL: Performance & Pixel Features =====
PixelSetupWizard=1          # Pixel-style setup (replaces AOSP setup)
DevicePersonalization=1     # Pixel device personalization services
WebViewGoogle=1              # Better web rendering
DigitalWellbeing=1
AndroidAuto=1

# ===== EXCLUDE GOOGLE APPS YOU DON'T WANT =====
# Set to 0 to exclude (these are excluded by default)
GoogleTTS=0
GoogleAssistant=0
PixelLauncher=0
VR=0
Books=0
News=0
PlayGames=0