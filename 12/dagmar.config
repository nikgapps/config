# NikGapps configuration file for Dagmar Custom Build
# Target: LineageOS 19.1 (Android 12)

AndroidVersion=12
Version=38
LogDirectory=default
InstallPartition=default
Mode=install
WipeDalvikCache=1
WipeRuntimePermissions=1
ExecuteBackupRestore=1
UseZipConfig=0
OverwriteWithZipConfig=0
GmsOptimization=0
GenerateLogs=1

# ==========================================
# Core & System Components (Zorunlu Altyapı)
# ==========================================
Core=1
ExtraFiles=1
GooglePlayStore=1
GoogleServicesFramework=1
GoogleContactsSyncAdapter=1
GoogleCalendarSyncAdapter=1
GmsCore=1

# ==========================================
# Seçtiğiniz ve Aktif Edilen Google Uygulamaları
# ==========================================
GoogleMessages=1
GoogleDialer=1
GoogleContacts=1
CarrierServices=1
GoogleCalculator=1
Drive=1
GooglePhotos=1
GBoard=1
GoogleCalendar=1
Gmail=1
YouTube=1
YouTubeMusic=1
GoogleSearch=1
Velvet=1
Gemini=1

# Temiz Kurulum İçin Gerekli Kurulum Sihirbazı
SetupWizard=1
GoogleRestore=1
GoogleOneTimeInitializer=1

# ==========================================
# Kapatılan/Yüklenmeyecek Diğer Paketler
# ==========================================
DigitalWellbeing=0
GoogleClock=0
GoogleMaps=0
GoogleLocationHistory=0
DeviceHealthServices=0
GoogleKeep=0

PixelSpecifics=0
PixelLauncher=0
DevicePersonalizationServices=0
GoogleWallpaper=0
QuickAccessWallet=0
SettingsServices=0
PrivateComputeServices=0
PixelThemes=0
EmojiWallpaper=0
PixelWeather=0
AICore=0

PlayGames=0
GoogleRecorder=0

GoogleFiles=0
StorageManager=0
DocumentsUIGoogle=0

MarkupGoogle=0
GoogleTTS=0
GoogleSounds=0
GoogleChrome=0
WebViewGoogle=0
TrichromeLibrary=0
DeviceSetup=0
AndroidAuto=0
GooglePartnerSetup=1
AndroidDevicePolicy=0
CoreGo=0
GoogleGo=0
AssistantGo=0
MapsGo=0
NavigationGo=0
GalleryGo=0
GmailGo=0
PixelSetupWizard=0
Meet=0
GoogleDocs=0
GoogleSheets=0
GoogleSlides=0
Books=0
GoogleTalkback=0
GooglePersonalSafety=0

# ==========================================
# LineageOS Sistem Uygulamalarını Temizleme
# ==========================================
# NikGapps debloater starts here

/system/priv-app/Dialer
/system/priv-app/Contacts
/system/app/Messaging
/system/product/app/Gallery2
/system/app/ExactCalculator
/system/app/Calendar
/system/app/LatinIME
/system/app/Jelly
